{
  "name": "n8nforge",
  "version": "0.1.0",
  "description": "CLI for n8n bootstrap and provisioning",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "n8nforge": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
