{
  "name": "@n8nforge/core",
  "version": "0.1.0",
  "description": "n8nforge bootstrap engine",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
